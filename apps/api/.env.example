# API Server — core
DATABASE_URL=postgresql://paperdb:paperdb_secret@localhost:5432/paperdb
REDIS_URL=redis://localhost:6379
PORT=3001

# Security (REQUIRED in production — API will refuse to start without these)
JWT_SECRET=change-this-to-a-256-bit-secret-in-production
SOCKET_SECRET=change-this-to-a-different-256-bit-secret-in-production

# CORS — comma-separated list of allowed origins (leave empty to allow all in dev)
CORS_ORIGINS=http://localhost:3000,https://yourapp.com

# Storage (S3/R2/MinIO — all three are required for real file uploads)
CDN_BASE_URL=https://cdn.paperdb.dev
STORAGE_BASE_URL=https://storage.paperdb.dev
S3_BUCKET=paperdb-files
S3_REGION=us-east-1
S3_ENDPOINT=                  # leave empty for AWS S3; set for MinIO / Cloudflare R2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# OAuth social login (optional — only needed if using signInWithOAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3001
